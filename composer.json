{
    "name": "sumaiazaman/laravel-sqs-redrive",
    "description": "Native AWS SQS dead letter queue (DLQ) support for Laravel. Automatically detects redrive policies, aligns retry counts with maxReceiveCount, and lets SQS handle failed job routing.",
    "keywords": ["laravel", "sqs", "queue", "dead-letter-queue", "dlq", "redrive", "aws"],
    "license": "MIT",
    "authors": [
        {
            "name": "Sumaia Zaman",
            "email": "sumaiazaman@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/queue": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "aws/aws-sdk-php": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "SumaiaZaman\\SqsRedrive\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SumaiaZaman\\SqsRedrive\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SumaiaZaman\\SqsRedrive\\SqsRedriveServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
